#!/usr/bin/env bash
# Pre-push security hook — blocks pushes containing sensitive files or secrets

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0

echo "Running pre-push security checks..."

# Determine which files to scan: commits ahead of origin, or staged files if no origin/commits yet
if git rev-parse origin/HEAD &>/dev/null; then
  CHANGED_FILES=$(git diff --name-only origin/HEAD...HEAD 2>/dev/null || true)
else
  CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
fi

# 1. Block node_modules/ and dist/ from being pushed
FORBIDDEN_PATHS=$(echo "$CHANGED_FILES" | grep -E '^(node_modules|dist)/' || true)
if [ -n "$FORBIDDEN_PATHS" ]; then
  echo -e "${RED}BLOCKED:${NC} Push contains forbidden paths:"
  echo "$FORBIDDEN_PATHS"
  ERRORS=$((ERRORS + 1))
fi

# 2. Block .env files
ENV_FILES=$(echo "$CHANGED_FILES" | grep -E '(^|/)\.env' || true)
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}BLOCKED:${NC} Push contains .env files:"
  echo "$ENV_FILES"
  ERRORS=$((ERRORS + 1))
fi

# 3. Scan for secrets with git-secrets
if command -v git-secrets &>/dev/null; then
  if ! git secrets --scan 2>/dev/null; then
    echo -e "${RED}BLOCKED:${NC} git-secrets detected potential credentials in committed files."
    ERRORS=$((ERRORS + 1))
  fi
else
  echo -e "${YELLOW}WARNING:${NC} git-secrets not found — install with: brew install git-secrets"
fi

# 4. Run npm audit if this is a Node project
if [ -f package.json ]; then
  echo "Running npm audit..."
  if ! npm audit --audit-level=high 2>&1; then
    echo -e "${YELLOW}WARNING:${NC} npm audit found high/critical vulnerabilities. Review before pushing."
  fi
fi

if [ "$ERRORS" -gt 0 ]; then
  echo -e "\n${RED}Push blocked: $ERRORS security issue(s) found. Fix them before pushing.${NC}"
  exit 1
fi

echo "All security checks passed."
